# pixi environments
.pixi/*
!.pixi/config.toml

# local OS / interpreter byproducts
.DS_Store
__pycache__/
.pytest_cache/
benchmarks/__pycache__/
benchmarks/julia-env/*
!benchmarks/julia-env/Project.toml
!benchmarks/julia-env/Manifest.toml

# generated benchmark data
*.parquet
benchmarks/data/*.hash

# Correia HDFE benchmark data (download separately, ~600MB of CSVs)
# metadata and READMEs stay tracked; see data/correia_data/README.md
data/correia_data/*.csv

# Reproducibility run artifacts. Canonical paper summaries and generated Typst
# fragments are tracked; raw timing runs remain local.
results/runs/
results/legacy/
benchmarks/results/
benchmarks/modular/*.csv
data/benchmarks/*.csv
figures/benchmarks/

# local Codex skill marker
academic-voice.skill
academic-voice/

# local assistant/project metadata
.claude/
.cluade/
.serena/
